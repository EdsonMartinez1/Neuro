    <!-- FAQ -->
    <string name="faq_titulo">Frequently asked questions</string>
    <string name="faq_pregunta_1">How does the app work?</string>
    <string name="faq_respuesta_1">Neuro is a mental wellness app that offers tools such as meditation, breathing exercises, an emotional journal and a support chat.</string>
    <string name="faq_pregunta_2">Is my data safe?</string>
    <string name="faq_respuesta_2">Yes. All your information is confidential and protected. Check our privacy policy for more details.</string>
    <string name="faq_pregunta_3">What does the Premium plan include?</string>
    <string name="faq_respuesta_3">The Premium plan unlocks all tools, unlimited guided sessions, exclusive content and advanced tracking.</string>
    <string name="faq_pregunta_4">Can I cancel my subscription?</string>
    <string name="faq_respuesta_4">Yes, you can cancel at any time from your profile in the Current plan section.</string>
    <string name="faq_pregunta_5">Does the app replace a professional?</string>
    <string name="faq_respuesta_5">No. Neuro is a complementary support tool. If you need urgent help, use the Emergency button in your profile.</string>
    <string name="faq_pregunta_6">How do I contact support?</string>
    <string name="faq_respuesta_6">Go to Profile, then Support and then Contact support. Send us a message and we will get back to you as soon as possible.</string>

